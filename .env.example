# ============================================================
# Database
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lampang_bus
DB_USER=lampang
DB_PASSWORD=lampang_pass
DB_ROOT_PASSWORD=root_secret

# ============================================================
# JWT
# ============================================================
# Must be at least 32 characters, keep secret
JWT_SECRET=change_this_to_a_random_secret_at_least_32_chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# LINE Messaging API (fill in Phase 6)
# ============================================================
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_LIFF_ID=

# ============================================================
# Application
# ============================================================
PORT=3000
NODE_ENV=development
TZ=Asia/Bangkok
CURRENT_TERM=2568-2

# ============================================================
# Export
# ============================================================
# Path to THSarabunNew.ttf for PDF export (Phase 3+)
PDF_FONT_PATH=./fonts/THSarabunNew.ttf
