# Hour (0-23, local browser time) used as fallback when the backend session
# cannot be reached. The backend (DRIVER_SESSION_SWITCH_HOUR) is the source
# of truth; this value is only used if the status-today request fails.
# Before this hour = morning (ส่งเช้า). From this hour onward = evening (รับเย็น).
VITE_DRIVER_SESSION_SWITCH_HOUR=12
