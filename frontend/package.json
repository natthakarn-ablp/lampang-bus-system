{
  "name": "lampang-bus-frontend",
  "version": "1.0.0",
  "description": "Lampang Bus System — Frontend",
  "type": "module",
  "scripts": {
    "dev":     "vite",
    "build":   "vite build",
    "preview": "vite preview",
    "check:labels": "node ../scripts/check-ui-labels.js",
    "check:labels:strict": "node ../scripts/check-ui-labels.js --strict",
    "check:labels:verbose": "node ../scripts/check-ui-labels.js --verbose",
    "hooks:install": "node ../scripts/install-hooks.js",
    "hooks:install:strict": "node ../scripts/install-hooks.js --strict",
    "hooks:remove": "node ../scripts/install-hooks.js --remove"
  },
  "dependencies": {
    "axios":            "^1.7.2",
    "react":            "^18.3.1",
    "react-dom":        "^18.3.1",
    "react-router-dom": "^6.24.0"
  },
  "devDependencies": {
    "@types/react":           "^18.3.3",
    "@types/react-dom":       "^18.3.0",
    "@vitejs/plugin-react":   "^4.3.1",
    "autoprefixer":           "^10.4.19",
    "postcss":                "^8.4.39",
    "tailwindcss":            "^3.4.6",
    "vite":                   "^5.3.3"
  }
}
